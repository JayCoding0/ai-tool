# ============================================================
# Docker 构建忽略文件
# 减少构建上下文大小，加速构建
# ============================================================

# Git
.git
.gitignore

# IDE
.idea/
.vscode/
.codebuddy/
*.swp
*.swo

# 文档（运行时不需要）
docs/
README.md
LICENSE

# 日志
logs/
*.log

# 编译产物（容器内重新编译）
output/
*.exe
*.out

# 配置文件（通过 volume 挂载）
trpc_go.yaml
trpc_go.yaml.example

# Docker 自身
Dockerfile
docker-compose.yml
.dockerignore

# macOS
.DS_Store

# Python 缓存
__pycache__/
*.pyc
*.pyo

# Go vendor（容器内重新下载）
vendor/

# 脚本（运行时不需要）
scripts/
