# ============================================================
# Docker Compose 环境变量配置
# 复制此文件为 .env 并修改配置
# 用法: cp .env.example .env
# ============================================================

# ─── 端口配置 ────────────────────────────────────────────
HTTP_PORT=80                # Nginx 对外端口（浏览器访问）
MCP_PORT=8001               # MCP 服务端口（直连后端）
MYSQL_PORT=3306
# HTTPS_PORT=443            # HTTPS 端口（生产环境取消注释）

# ─── MySQL 配置 ──────────────────────────────────────────
MYSQL_ROOT_PASSWORD=ai_agent_2024
